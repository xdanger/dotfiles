[user]
    name = Kros Dai
    email = xdanger@gmail.com
    signingkey = ~/.ssh/singapore
[gpg]
    format = ssh
[commit]
    gpgsign = true
[core]
	pager = delta
	excludesFile = ~/.dotfiles/git/gitignore
[alias]
    st = status
    br = branch -a
    ci = "!claude --permission-mode bypassPermissions -p \"/git-commit\" --model sonnet"
    co = checkout
    clone-bare-for-worktrees = "!zsh -lc 'script=\"\"; if [[ -n \"${DOTFILES:-}\" && -x \"${DOTFILES}/bin/git-clone-bare-for-worktrees.zsh\" ]]; then script=\"${DOTFILES}/bin/git-clone-bare-for-worktrees.zsh\"; elif command -v git-clone-bare-for-worktrees.zsh >/dev/null 2>&1; then script=\"$(command -v git-clone-bare-for-worktrees.zsh)\"; else for config in \"$HOME/.gitconfig\" \"$HOME/.config/git/config\"; do if [[ -e \"$config\" ]]; then real_config=${config:A}; candidate=${real_config:h:h}/bin/git-clone-bare-for-worktrees.zsh; if [[ -x \"$candidate\" ]]; then script=\"$candidate\"; break; fi; fi; done; fi; [[ -n \"$script\" ]] || script=\"$HOME/.dotfiles/bin/git-clone-bare-for-worktrees.zsh\"; exec zsh \"$script\" \"$@\"' zsh \"$@\""
[init]
    defaultBranch = main
[pull]
    rebase = false
[color]
    diff = auto
    status = auto
    branch = auto
    ui = true
[interactive]
    diffFilter = delta --color-only
[diff "word"]
    textconv = strings
[merge]
	conflictStyle = zdiff3
[i18n]
    commitencoding = UTF-8
[http]
    postBuffer = 524288000
[worktree]
	useRelativePaths = true
[delta]
	navigate = true
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    required = true
    process = git-lfs filter-process
[filter "media"]
    clean = git-media-clean %f
    smudge = git-media-smudge %f

[credential "https://huggingface.co"]
    provider = generic
[credential "https://dev.azure.com"]
    useHttpPath = true
[credential "https://git.tapsvc.com"]
	helper =
	helper = !glab auth git-credential
