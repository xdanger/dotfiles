[user]
    name = Kros Dai
    email = xdanger@gmail.com
    signingkey = ~/.ssh/singapore
[gpg]
    format = ssh
[commit]
    gpgsign = true
[core]
	pager = delta
[alias]
    st = status
    br = branch -a
    ci = "!claude --permission-mode bypassPermissions -p \"/git-commit\" --model sonnet"
    co = checkout
    clone-bare-for-worktrees = "!f(){ script=\"$HOME/.dotfiles/bin/git-clone-bare-for-worktrees.zsh\"; origin=$(git config --global --show-origin --get alias.clone-bare-for-worktrees 2>/dev/null | awk '{print $1}'); case \"$origin\" in file:*) config_path=${origin#file:}; if [ -e \"$config_path\" ]; then candidate=$(cd \"$(dirname \"$config_path\")/..\" && pwd)/bin/git-clone-bare-for-worktrees.zsh; [ -x \"$candidate\" ] && script=\"$candidate\"; fi ;; esac; exec zsh \"$script\" \"$@\"; }; f"
[init]
    defaultBranch = main
[pull]
    rebase = false
[color]
    diff = auto
    status = auto
    branch = auto
    ui = true
[interactive]
    diffFilter = delta --color-only
[diff "word"]
    textconv = strings
[merge]
	conflictStyle = zdiff3
[i18n]
    commitencoding = UTF-8
[http]
    postBuffer = 524288000
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    required = true
    process = git-lfs filter-process
[filter "media"]
    clean = git-media-clean %f
    smudge = git-media-smudge %f
[credential "https://huggingface.co"]
    provider = generic
[credential "https://dev.azure.com"]
    useHttpPath = true
[worktree]
	useRelativePaths = true
[delta]
	navigate = true
