# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
#theme = light:Monokai Pro Light Sun,dark:Monokai Pro Spectrum
theme = Monokai Pro Spectrum
background-opacity = 0.97
background-blur = true
# cursor-style = bar
font-family = iMWritingMono Nerd Font
font-size = 14
font-thicken = true
font-thicken-strength = 128
font-feature = +liga
font-synthetic-style = false
font-style-bold = false
adjust-cell-width = -16%
adjust-cell-height = +24%
adjust-box-thickness = +20%
window-height = 32
window-width = 128
window-padding-x = 12
window-padding-y = 8
window-padding-balance = true
window-title-font-family = Geist
window-decoration = true

#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

# ============ macOS 必备 ============
# 让 Option+Enter / Option+P 等 Claude Code 快捷键能工作
macos-option-as-alt = true

# ============ Multi-line 显式绑定（保险起见） ============
# 默认情况下 Ghostty 已正确发送 Shift+Enter；
# 但若你在 SSH / 容器内使用，建议显式声明：
keybind = shift+enter=text:\x1b\r

# ============ 全局快捷终端（quick terminal 下拉式） ============
# 避开 macOS 默认的 Cmd+` App 内窗口切换
keybind = global:ctrl+cmd+grave_accent=toggle_quick_terminal

# ============ 分屏（多 Claude Code 实例并行） ============
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right
# 临时放大单个 pane
keybind = cmd+shift+enter=toggle_split_zoom

# ============ Shell 集成（pwd 同步、OSC 7） ============
shell-integration = detect
shell-integration-features = cursor,sudo,title,ssh-terminfo

# ============ 大滚动缓冲（应对 Claude Code 长输出） ============
# 默认 10k 行偏小
scrollback-limit = 100000

# ============ 触控板/鼠标 ============
mouse-scroll-multiplier = 3
copy-on-select = clipboard
